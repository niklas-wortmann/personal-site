---
import type { CollectionEntry } from 'astro:content'
import FormattedDate from '../components/FormattedDate.astro'
import { Image } from 'astro:assets'
import Layout from '../components/Layout.astro'

type Props = CollectionEntry<'blog'>['data'] & { id: string }

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageAlt,
  socialMediaImage,
  keywords,
  id,
} = Astro.props
const isOneAgentPost = id.includes('one-agent')
console.log({ id, isOneAgentPost })
---

<Layout
  title={title}
  description={description}
  image={socialMediaImage?.src ?? heroImage.src}
  keywords={keywords}
>
  <style>
    article {
      width: 100%;
    }

    .hero-image {
      width: min(1020px, calc(100% - 2rem));
      margin: 0 auto 2.5rem;
    }

    .hero-image img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 14px;
      box-shadow: 0 20px 45px rgba(0, 0, 0, 0.25);
    }

    .prose {
      width: min(1020px, calc(100% - 2rem));
      margin: 0 auto;
      color: #e8ddd0;
    }

    .prose > :where(p, ul, ol, blockquote, h2, h3, h4, h5, hr) {
      max-width: 84ch;
      margin-left: auto;
      margin-right: auto;
    }

    .prose > p:has(> img:only-child) {
      max-width: 100%;
    }

    .prose
      > :where(
        pre,
        .expressive-code,
        table,
        .post-footer,
        .post-footer-divider
      ) {
      max-width: 100%;
    }

    .title {
      margin-bottom: 2rem;
      text-align: center;
    }

    .title h1 {
      margin: 0.75rem 0 0;
      line-height: 1.15;
      padding: 0;
    }

    .title hr {
      margin: 1.5rem auto 0;
      border: 0;
      border-top: 1px solid rgba(232, 221, 208, 0.24);
    }

    .date {
      margin-bottom: 0.25rem;
      color: rgba(232, 221, 208, 0.75);
      font-size: 0.95rem;
    }

    .last-updated-on {
      margin-top: 0.35rem;
      font-style: italic;
    }

    .prose :where(p, ul, ol, blockquote, pre, table, figure) {
      margin-top: 1rem;
      margin-bottom: 1rem;
    }

    .prose :where(h2, h3) {
      padding-top: 0;
      padding-bottom: 0;
      line-height: 1.2;
    }

    .prose h2 {
      margin-top: 2.5rem;
      margin-bottom: 0.9rem;
    }

    .prose h3 {
      margin-top: 2rem;
      margin-bottom: 0.7rem;
    }

    .prose p {
      line-height: 1.8;
    }

    .prose ul,
    .prose ol {
      padding-left: 1.5rem;
    }

    .prose li {
      margin: 0.45rem 0;
      padding-left: 0.25rem;
    }

    .prose hr {
      margin: 2.5rem 0;
      border: 0;
      border-top: 1px solid rgba(232, 221, 208, 0.18);
    }

    .prose img {
      display: block;
      width: 100%;
      margin: 2rem auto;
      border-radius: 12px;
      border: 1px solid rgba(232, 221, 208, 0.16);
    }

    .prose :not(pre) > code {
      padding: 0.15rem 0.4rem;
      border-radius: 0.4rem;
      background: rgba(0, 0, 0, 0.25);
    }

    @media (max-width: 768px) {
      .hero-image {
        width: calc(100% - 1.25rem);
        margin-bottom: 1.75rem;
      }

      .prose {
        width: calc(100% - 1.25rem);
      }

      .title {
        margin-bottom: 1.5rem;
      }

      .prose h2 {
        margin-top: 2rem;
      }
    }

    /* One-off editorial style for the one-agent article */
    .one-agent-post .prose {
      counter-reset: section;
      font-size: 1.04rem;
    }

    .one-agent-post .title {
      margin-bottom: 2.35rem;
    }

    .one-agent-post .title h1 {
      letter-spacing: 0.01em;
    }

    .one-agent-post .prose > p:first-of-type {
      max-width: 100%;
      margin: 0 auto 1.25rem;
      text-align: center;
    }

    .one-agent-post .prose > p:first-of-type em {
      display: inline-block;
      font-style: normal;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.76rem;
      color: #f2b35e;
      border: 1px solid rgba(232, 164, 74, 0.35);
      border-radius: 999px;
      padding: 0.45rem 0.9rem;
      background: linear-gradient(
        120deg,
        rgba(232, 164, 74, 0.2),
        rgba(232, 164, 74, 0.06)
      );
    }

    .one-agent-post .prose > p:nth-of-type(2) {
      font-size: 1.16rem;
      line-height: 1.72;
      color: #f3eadf;
      max-width: 76ch;
    }

    .one-agent-post .prose h2 {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      margin-top: 2.85rem;
      margin-bottom: 1rem;
      max-width: 100%;
    }

    .one-agent-post .prose h2::before {
      counter-increment: section;
      content: counter(section, decimal-leading-zero);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.77rem;
      letter-spacing: 0.09em;
      color: #f2b35e;
      border: 1px solid rgba(232, 164, 74, 0.38);
      border-radius: 999px;
      padding: 0.28rem 0.58rem;
      background: rgba(35, 12, 4, 0.7);
      line-height: 1;
      flex-shrink: 0;
    }

    .one-agent-post .prose h3 {
      color: #f2dfc6;
    }

    .one-agent-post .prose blockquote {
      border-left: 4px solid #e8a44a;
      border-radius: 12px;
      border-top-left-radius: 4px;
      border-bottom-left-radius: 4px;
      background: linear-gradient(
        120deg,
        rgba(232, 164, 74, 0.22),
        rgba(232, 164, 74, 0.07)
      );
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
      padding: 1rem 1.2rem;
      max-width: 76ch;
    }

    .one-agent-post .prose blockquote p {
      line-height: 1.65;
      color: #f4e7d6;
      font-size: 1.06rem;
    }

    .one-agent-post .prose ul li::marker,
    .one-agent-post .prose ol li::marker {
      color: #e8a44a;
      font-weight: 700;
    }

    .one-agent-post .prose strong {
      color: #fff2dd;
    }

    .one-agent-post .prose > hr {
      max-width: 100%;
    }

    @media (max-width: 768px) {
      .one-agent-post .prose {
        font-size: 1rem;
      }

      .one-agent-post .prose > p:nth-of-type(2) {
        font-size: 1.08rem;
      }

      .one-agent-post .prose h2 {
        margin-top: 2.3rem;
      }
    }
  </style>

  <style is:global>
    article.blog-post .prose > :is(p, ul, ol, blockquote, pre, table, figure) {
      margin-top: 1rem;
      margin-bottom: 1rem;
    }

    article.blog-post .prose > :is(p, ul, ol, blockquote, h2, h3, h4, h5, hr) {
      max-width: 84ch;
      margin-left: auto;
      margin-right: auto;
    }

    article.blog-post .prose > p:has(> img:only-child),
    article.blog-post .prose > :is(pre, .expressive-code, table, .post-footer, .post-footer-divider) {
      max-width: 100%;
    }

    article.blog-post .prose > h2,
    article.blog-post .prose > h3 {
      padding-top: 0;
      padding-bottom: 0;
      line-height: 1.2;
    }

    article.blog-post .prose > h2 {
      margin-top: 2.5rem;
      margin-bottom: 0.9rem;
    }

    article.blog-post .prose > h3 {
      margin-top: 2rem;
      margin-bottom: 0.7rem;
    }

    article.blog-post .prose p {
      line-height: 1.8;
    }

    article.blog-post .prose ul,
    article.blog-post .prose ol {
      padding-left: 1.5rem;
    }

    article.blog-post .prose li {
      margin: 0.45rem 0;
      padding-left: 0.25rem;
    }

    article.blog-post .prose hr {
      margin: 2.5rem 0;
      border: 0;
      border-top: 1px solid rgba(232, 221, 208, 0.18);
    }

    article.blog-post .prose img {
      display: block;
      width: 100%;
      margin: 2rem auto;
      border-radius: 12px;
      border: 1px solid rgba(232, 221, 208, 0.16);
    }

    article.blog-post .prose :not(pre) > code {
      padding: 0.15rem 0.4rem;
      border-radius: 0.4rem;
      background: rgba(0, 0, 0, 0.25);
    }

    article.blog-post.one-agent-post .prose {
      counter-reset: section;
      font-size: 1.04rem;
    }

    article.blog-post.one-agent-post .title {
      margin-bottom: 2.35rem;
    }

    article.blog-post.one-agent-post .title h1 {
      letter-spacing: 0.01em;
    }

    article.blog-post.one-agent-post .prose > p:first-of-type {
      max-width: 100%;
      margin: 0 auto 1.25rem;
      text-align: center;
    }

    article.blog-post.one-agent-post .prose > p:first-of-type em {
      display: inline-block;
      font-style: normal;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.76rem;
      color: #f2b35e;
      border: 1px solid rgba(232, 164, 74, 0.35);
      border-radius: 999px;
      padding: 0.45rem 0.9rem;
      background: linear-gradient(120deg, rgba(232, 164, 74, 0.2), rgba(232, 164, 74, 0.06));
    }

    article.blog-post.one-agent-post .prose > p:nth-of-type(2) {
      font-size: 1.16rem;
      line-height: 1.72;
      color: #f3eadf;
      max-width: 76ch;
    }

    article.blog-post.one-agent-post .prose > h2 {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      margin-top: 2.85rem;
      margin-bottom: 1rem;
      max-width: 100%;
    }

    article.blog-post.one-agent-post .prose > h2::before {
      counter-increment: section;
      content: counter(section, decimal-leading-zero);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.77rem;
      letter-spacing: 0.09em;
      color: #f2b35e;
      border: 1px solid rgba(232, 164, 74, 0.38);
      border-radius: 999px;
      padding: 0.28rem 0.58rem;
      background: rgba(35, 12, 4, 0.7);
      line-height: 1;
      flex-shrink: 0;
    }

    article.blog-post.one-agent-post .prose > h3 {
      color: #f2dfc6;
    }

    article.blog-post.one-agent-post .prose > blockquote {
      border-left: 4px solid #e8a44a;
      border-radius: 12px;
      border-top-left-radius: 4px;
      border-bottom-left-radius: 4px;
      background: linear-gradient(120deg, rgba(232, 164, 74, 0.22), rgba(232, 164, 74, 0.07));
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
      padding: 1rem 1.2rem;
      max-width: 76ch;
    }

    article.blog-post.one-agent-post .prose blockquote p {
      line-height: 1.65;
      color: #f4e7d6;
      font-size: 1.06rem;
    }

    article.blog-post.one-agent-post .prose ul li::marker,
    article.blog-post.one-agent-post .prose ol li::marker {
      color: #e8a44a;
      font-weight: 700;
    }

    article.blog-post.one-agent-post .prose strong {
      color: #fff2dd;
    }

    article.blog-post.one-agent-post .prose > hr {
      max-width: 100%;
    }

    @media (max-width: 768px) {
      article.blog-post .prose {
        width: calc(100% - 1.25rem);
      }

      article.blog-post .hero-image {
        width: calc(100% - 1.25rem);
        margin-bottom: 1.75rem;
      }

      article.blog-post .title {
        margin-bottom: 1.5rem;
      }

      article.blog-post .prose > h2 {
        margin-top: 2rem;
      }

      article.blog-post.one-agent-post .prose {
        font-size: 1rem;
      }

      article.blog-post.one-agent-post .prose > p:nth-of-type(2) {
        font-size: 1.08rem;
      }

      article.blog-post.one-agent-post .prose > h2 {
        margin-top: 2.3rem;
      }
    }
  </style>

  <article class:list={{ 'blog-post': true, 'one-agent-post': isOneAgentPost }}>
    <div class="hero-image">
      {
        heroImage && (
          <Image
            width={1020}
            height={510}
            src={heroImage}
            alt={heroImageAlt}
            loading="eager"
            transition:name={`heroImage-${id}`}
          />
        )
      }
    </div>
    <div class="prose">
      <div class="title">
        <div class="date">
          <FormattedDate date={pubDate} />
          {
            updatedDate && (
              <div class="last-updated-on">
                Last updated on <FormattedDate date={updatedDate} />
              </div>
            )
          }
        </div>
        <h1>{title}</h1>
        <hr />
      </div>
      <slot />
    </div>
  </article>
</Layout>
